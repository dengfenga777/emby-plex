APP_NAME=MoviePilot Request System
SECRET_KEY=change-me-before-production
DATABASE_URL=sqlite:///./moviepilot_requests.db
DEV_AUTH_ENABLED=true
REQUIRE_ADMIN_APPROVAL=true
DEFAULT_ADMIN_IDS=1
CORS_ORIGINS=["http://localhost:5173"]

# MoviePilot integration mode:
# - mock: use built-in fake search/task progression for local development
# - api: connect to a real MoviePilot server (/api/v1)
MOVIEPILOT_MODE=mock
MOVIEPILOT_BASE_URL=http://localhost:3001

# Preferred: reuse MoviePilot's API_TOKEN via X-API-KEY
MOVIEPILOT_API_KEY=

# Optional fallback: use MoviePilot username/password login to fetch Bearer token
MOVIEPILOT_USERNAME=
MOVIEPILOT_PASSWORD=
MOVIEPILOT_OTP_PASSWORD=
MOVIEPILOT_TIMEOUT_SECONDS=20

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:5173
